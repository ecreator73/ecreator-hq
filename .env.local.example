# ---------------------------------------------------------------------------
# eCreator OS - Umgebungsvariablen (Vorlage)
# ---------------------------------------------------------------------------
# Kopiere diese Datei zu ".env.local" und trage deine echten Supabase-Werte ein.
# NIEMALS echte Secrets in Git commiten - .env.local ist via .gitignore ausgeschlossen.
#
# Werte findest du im Supabase Dashboard:
#   Project Settings -> Data API / API Keys
# ---------------------------------------------------------------------------

# Oeffentliche Projekt-URL (Browser + Server)
NEXT_PUBLIC_SUPABASE_URL=

# Oeffentlicher anon Key (Browser + Server, durch RLS geschuetzt)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role Key - NUR serverseitig! Umgeht RLS. Niemals an den Browser geben.
# Wird nur vom Admin-Bootstrap-Skript (scripts/create-admin.mjs) genutzt.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Erster Super-Admin (nur fuer das einmalige Bootstrap-Skript "npm run create-admin")
# Kein Passwort hardcoden - hier nur lokal fuer den einmaligen Lauf setzen,
# danach wieder leeren oder Passwort sofort aendern.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=

# ---------------------------------------------------------------------------
# Phase 9 - AI & Automation Layer
# Schluessel zum Verschluesseln von Integrations-Credentials (AES-256-GCM).
# Mind. 16 Zeichen, zufaellig. OHNE diesen Wert koennen keine API-Keys/
# Credentials gespeichert werden (bewusst: kein unverschluesseltes Ablegen).
#   z.B. erzeugen mit:  openssl rand -base64 48
# ---------------------------------------------------------------------------
CREDENTIALS_SECRET=
